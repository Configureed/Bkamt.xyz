{
  "name": "obsidian-glass-loader",
  "version": "1.0.0",
  "description": "Obsidian Glass - Dark, futuristic Electron loader with sleek panels and glossy highlights",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never  ",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": ["electron", "loader", "obsidian", "glass", "futuristic", "dark", "cyber"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.00",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.obsidianglassloader.app",
    "productName": "Obsidian Glass Loader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ]
  }
} 